#
# Adapted from sdcadm/tools/mk-shar. Generalized so it can wrap any tool
# into a self-extracting shell archive — not just sdcadm.
#
# Convention: the proto directory must contain an `install.sh` at its
# top level. All other files/dirs in the proto are tarred (pigz) into
# `contents.tgz`. The resulting shar uuencodes both install.sh and
# contents.tgz, so when exec'd it self-extracts to a tempdir, untars
# contents.tgz, and runs `bash ./install.sh "$@"` with any args the
# caller passed. Why this shape:
#
#   * shar(1) uuencodes binary content, dodging the `tail -n` /
#     `tail -c` pitfalls that bite appended-binary tarballs on illumos
#     (the initial try for monitor-reef, which worked on macOS and
#     failed on SmartOS with "tar: directory checksum error").
#
#   * sdcadm experimental get-tritonadm downloads the shar and execs
#     it directly, so this matches the contract sdcadm already expects.
#
# Usage:
#   mk-shar -n <name> -s <stamp> -d <proto_dir> -o <output.sh>
#

if [[ -n "$TRACE" ]]; then
    export PS4='[\D{%FT%TZ}] ${BASH_SOURCE}:${LINENO}: ${FUNCNAME[0]:+${FUNCNAME[0]}(): }'
    set -o xtrace
fi
set -o errexit
set -o pipefail


#---- support stuff

function fatal {
    echo "$0: fatal error: $*" >&2
    exit 1
}

function usage {
    echo "Usage: $0 -n <name> -s <stamp> -d <proto_dir> -o <output.sh>" >&2
    exit 2
}


#---- mainline

NAME=""
STAMP=""
PROTO=""
OUTPUT=""

while getopts "n:s:d:o:" c; do
    case "$c" in
        n) NAME=$OPTARG ;;
        s) STAMP=$OPTARG ;;
        d) PROTO=$OPTARG ;;
        o) OUTPUT=$OPTARG ;;
        *) usage ;;
    esac
done

[[ -n "$NAME"   ]] || usage
[[ -n "$STAMP"  ]] || usage
[[ -n "$PROTO"  ]] || usage
[[ -n "$OUTPUT" ]] || usage

[[ -d "$PROTO" ]] || fatal "proto dir not found: $PROTO"
[[ -f "$PROTO/install.sh" ]] || fatal "missing $PROTO/install.sh (mk-shar convention)"

# Need GNU sharutils — macOS's BSD shar doesn't support -Q and uses a very
# different shar format (plain cat, not uudecoded).
SHAR=""
if command -v gshar >/dev/null 2>&1 && gshar --version 2>/dev/null | grep -q 'GNU sharutils'; then
    SHAR=gshar
elif command -v shar >/dev/null 2>&1 && shar --version 2>/dev/null | grep -q 'GNU sharutils'; then
    SHAR=shar
fi
[[ -n "$SHAR" ]] || fatal "GNU sharutils not found. On SmartOS: 'pkgin -y in gsharutils'. On macOS: 'brew install sharutils' (installs as 'gshar')."

# Pick GNU tar if available (gtar on illumos, tar on Linux). macOS ships
# BSD tar but it also accepts the flags we use.
if command -v gtar >/dev/null 2>&1; then
    TAR=gtar
else
    TAR=tar
fi


#---- build contents.tgz inside the proto dir

CONTENTS=$(cd "$PROTO" && ls | grep -v '^install\.sh$' | xargs || true)
if [[ -n "$CONTENTS" ]]; then
    (cd "$PROTO" \
        && $TAR -czf contents.tgz $CONTENTS \
        && rm -rf $CONTENTS)
else
    # No non-install.sh content; produce an empty tarball so the
    # extractor's `tar -xzf contents.tgz` is still well-defined.
    (cd "$PROTO" && $TAR -czf contents.tgz -T /dev/null)
fi


#---- write the shar

(cat <<HEADER_END
#!/bin/bash
#
# $NAME installer — self-extracting shell archive. Built by mk-shar.
#
# Honor TRACE=1 so sdcadm's installer-run stays debuggable (sdcadm sets
# this on its exec of the shar).
#

if [[ -n "\$TRACE" ]]; then
    export PS4='[\D{%FT%TZ}] \${BASH_SOURCE}:\${LINENO}: \${FUNCNAME[0]:+\${FUNCNAME[0]}(): }'
    set -o xtrace
fi
set -o errexit
set -o pipefail

echo "Extracting $NAME $STAMP"

TMPDIR=\$(mktemp -d -t $NAME-shar.XXXXXX)
trap 'rm -rf "\$TMPDIR"' EXIT
cd "\$TMPDIR"

HEADER_END
) > "$OUTPUT"

# shar -Q emits shell code that, when sourced, recreates install.sh and
# contents.tgz in cwd via uudecode-style here-docs. Strip its trailing
# `exit 0` so our postamble runs.
(cd "$PROTO" && $SHAR -Q install.sh contents.tgz | grep -v '^exit') >> "$OUTPUT"

cat <<POSTAMBLE_END >> "$OUTPUT"

tar -xzf contents.tgz
bash ./install.sh "\$@"
exit 0
POSTAMBLE_END

chmod 755 "$OUTPUT"

echo "Wrote $OUTPUT"
