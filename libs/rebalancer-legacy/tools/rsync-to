#
# Rsync rebalancer binaries and config to zones for quick dev iteration.
#
# Supports multi-CN deployments where the rebalancer and storage zones
# may be on remote compute nodes, not just the headnode.
#
# Usage:
#   ./tools/rsync-to HEADNODE-GZ-IP           # sync both manager + agent
#   ./tools/rsync-to HEADNODE-GZ-IP manager   # sync manager only
#   ./tools/rsync-to HEADNODE-GZ-IP agent     # sync agent only
#
# Set RELEASE=1 to use target/release/ instead of target/debug/.
#

if [[ -n "$TRACE" ]]; then
    export PS4='[\D{%FT%TZ}] ${BASH_SOURCE}:${LINENO}: ${FUNCNAME[0]:+${FUNCNAME[0]}(): }'
    set -o xtrace
fi
set -o errexit
set -o pipefail

TOP=$(cd $(dirname $0)/../; pwd)
SSH_OPTS="-q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
PROFILE=${RELEASE:+release}
PROFILE=${PROFILE:-debug}
# Workspace root is two levels above libs/rebalancer-legacy/
WORKSPACE_ROOT=$(cd ${TOP}/../..; pwd)
TARGET_DIR=${WORKSPACE_ROOT}/target/${PROFILE}

function fatal {
    echo "$0: fatal error: $*"
    exit 1
}

function restart_or_clear {
    local inst=$1 fmri=$2
    state=$(ssh $SSH_OPTS $HEADNODE svcs -z $inst -H -o state $fmri 2>/dev/null || echo "unknown")
    if echo "$state" | grep "maintenance" >/dev/null; then
        ssh $SSH_OPTS $HEADNODE svcadm -z $inst clear $fmri
    elif echo "$state" | grep "online" >/dev/null; then
        ssh $SSH_OPTS $HEADNODE svcadm -z $inst restart $fmri
    fi
}

# Restart or clear a service on a remote CN, hopping through the headnode.
function restart_or_clear_remote {
    local inst=$1 cn_ip=$2 fmri=$3
    local cn_ssh="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
    state=$(ssh $SSH_OPTS $HEADNODE \
        "ssh $cn_ssh -i /root/.ssh/sdc.id_rsa $cn_ip \
         svcs -z $inst -H -o state $fmri" 2>/dev/null || echo "unknown")
    if echo "$state" | grep "maintenance" >/dev/null; then
        ssh $SSH_OPTS $HEADNODE \
            "ssh $cn_ssh -i /root/.ssh/sdc.id_rsa $cn_ip \
             svcadm -z $inst clear $fmri"
    elif echo "$state" | grep "online" >/dev/null; then
        ssh $SSH_OPTS $HEADNODE \
            "ssh $cn_ssh -i /root/.ssh/sdc.id_rsa $cn_ip \
             svcadm -z $inst restart $fmri"
    fi
}

# Sync files to a zone on a remote CN by staging on the headnode first.
# Usage: sync_files_to_remote_zone <zone_uuid> <cn_ip> <dest_dir> <file1> [file2...]
function sync_files_to_remote_zone {
    local inst=$1 cn_ip=$2 dest_dir=$3
    shift 3
    local files=("$@")
    local cn_ssh="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
    local staging=/tmp/rsync-to-$$

    ssh $SSH_OPTS $HEADNODE "mkdir -p $staging"
    rsync -av "${files[@]}" $HEADNODE:$staging/

    for f in "${files[@]}"; do
        local base=$(basename "$f")
        ssh $SSH_OPTS $HEADNODE \
            "scp $cn_ssh -i /root/.ssh/sdc.id_rsa \
             $staging/$base $cn_ip:/tmp/$base && \
             ssh $cn_ssh -i /root/.ssh/sdc.id_rsa $cn_ip \
             'cp /tmp/$base /zones/$inst/root${dest_dir}/$base && \
              rm /tmp/$base'"
    done

    ssh $SSH_OPTS $HEADNODE "rm -rf $staging"
}

# Find zones on remote CNs via VMAPI + CNAPI.
# Returns "uuid cn_admin_ip" per line.
# Usage: find_remote_zones <alias_pattern>
function find_remote_zones {
    local alias_pat=$1

    echo "  Zone '$alias_pat' not found on headnode, querying VMAPI..." >&2

    # Read VMAPI and CNAPI domains from /usbkey/config (standard Triton location)
    local vmapi_domain cnapi_domain
    vmapi_domain=$(ssh $SSH_OPTS $HEADNODE "grep ^vmapi_domain= /usbkey/config | cut -d= -f2")
    cnapi_domain=$(ssh $SSH_OPTS $HEADNODE "grep ^cnapi_domain= /usbkey/config | cut -d= -f2")
    [[ -n "$vmapi_domain" ]] || fatal "could not read vmapi_domain from /usbkey/config"
    [[ -n "$cnapi_domain" ]] || fatal "could not read cnapi_domain from /usbkey/config"

    local vmapi_json
    vmapi_json=$(ssh $SSH_OPTS $HEADNODE \
        "curl -sS 'http://$vmapi_domain/vms?alias=$alias_pat&state=running'") \
        || fatal "VMAPI query failed"

    local count
    count=$(echo "$vmapi_json" | json length 2>/dev/null)
    [[ "${count:-0}" -gt 0 ]] || fatal "no running '$alias_pat' instances found on any CN"

    local headnode_uuid
    headnode_uuid=$(ssh $SSH_OPTS $HEADNODE "sysinfo | json UUID")

    for idx in $(seq 0 $(( count - 1 ))); do
        local uuid server_uuid
        uuid=$(echo "$vmapi_json" | json $idx.uuid)
        server_uuid=$(echo "$vmapi_json" | json $idx.server_uuid)

        # Skip zones on the headnode (vmadm should have found those)
        [[ "$server_uuid" != "$headnode_uuid" ]] || continue

        local cn_ip
        cn_ip=$(ssh $SSH_OPTS $HEADNODE \
            "curl -sS 'http://$cnapi_domain/servers/$server_uuid' | json sysinfo.\"Admin IP\"") \
            || fatal "CNAPI lookup failed for server $server_uuid"
        [[ -n "$cn_ip" ]] || fatal "could not resolve admin IP for server $server_uuid"
        echo "$uuid $cn_ip"
    done
}

function sync_manager {
    # Match rebalancer zone but not rebalancer-postgres or rebalancer-buckets-postgres
    local insts=$(ssh $SSH_OPTS $HEADNODE "vmadm lookup alias=~'^rebalancer\.' state=running")

    # Config files from the repo
    local MGR_CONFIG=${TOP}/manager/src/config.json
    local PG_CONF=${TOP}/etc/postgresql.conf

    [[ -f "${TARGET_DIR}/rebalancer-manager" ]] || \
        fatal "rebalancer-manager not found at ${TARGET_DIR}/rebalancer-manager"
    [[ -f "${TARGET_DIR}/rebalancer-adm" ]] || \
        fatal "rebalancer-adm not found at ${TARGET_DIR}/rebalancer-adm"

    # Sync to local rebalancer zones on the headnode
    if [[ -n "$insts" ]]; then
        echo "rebalancer instances (headnode): $insts"
        for inst in $insts; do
            local prefix=/zones/$inst/root/opt/smartdc/rebalancer
            echo "==> Syncing manager binaries + config to $inst (headnode)"
            rsync -av \
                ${TARGET_DIR}/rebalancer-manager \
                ${TARGET_DIR}/rebalancer-adm \
                $HEADNODE:$prefix/bin/
            [[ ! -f "$MGR_CONFIG" ]] || rsync -av $MGR_CONFIG $HEADNODE:$prefix/config.json
            [[ ! -f "$PG_CONF" ]]    || rsync -av $PG_CONF    $HEADNODE:$prefix/etc/
            restart_or_clear $inst svc:/manta/application/rebalancer
        done
    fi

    # Also sync to rebalancer zones on remote CNs
    echo "==> Checking for rebalancer zones on remote CNs..."
    local remote_zones
    remote_zones=$(find_remote_zones "rebalancer.") || true
    if [[ -n "$remote_zones" ]]; then
        local zone_count=$(echo "$remote_zones" | wc -l | tr -d ' ')
        echo "  Found remote rebalancer zones: $zone_count"
        while IFS= read -r line <&3; do
            local inst cn_ip
            inst=$(echo "$line" | awk '{print $1}')
            cn_ip=$(echo "$line" | awk '{print $2}')
            [[ -n "$inst" ]] || continue
            echo "==> Syncing manager binaries + config to $inst (CN $cn_ip)"

            (
                set +o errexit
                sync_files_to_remote_zone "$inst" "$cn_ip" \
                    /opt/smartdc/rebalancer/bin \
                    ${TARGET_DIR}/rebalancer-manager \
                    ${TARGET_DIR}/rebalancer-adm

                [[ ! -f "$MGR_CONFIG" ]] || \
                    sync_files_to_remote_zone "$inst" "$cn_ip" \
                        /opt/smartdc/rebalancer \
                        $MGR_CONFIG
                [[ ! -f "$PG_CONF" ]] || \
                    sync_files_to_remote_zone "$inst" "$cn_ip" \
                        /opt/smartdc/rebalancer/etc \
                        $PG_CONF

                restart_or_clear_remote "$inst" "$cn_ip" svc:/manta/application/rebalancer
            ) || echo "  WARNING: failed for $inst on $cn_ip, continuing..."
        done 3<<< "$remote_zones"
    fi
}

function sync_agent {
    local alias=${STORAGE_ALIAS:-storage}
    local insts=$(ssh $SSH_OPTS $HEADNODE vmadm lookup alias=~$alias state=running)

    # Use only the isolated agent build (no libpq).
    # Do NOT fall back to target/ — that binary has postgres linked.
    local AGENT_BIN=${TOP}/target-agent/${PROFILE}/rebalancer-agent
    [[ -f "$AGENT_BIN" ]] || fatal "rebalancer-agent not found at ${AGENT_BIN}
    Run 'make build-legacy' or 'make -C libs/rebalancer-legacy agent' first."

    # Sync to local storage zones on the headnode
    if [[ -n "$insts" ]]; then
        echo "$alias instances (headnode): $insts"
        for inst in $insts; do
            local prefix=/zones/$inst/root/opt/smartdc/rebalancer-agent
            echo "==> Syncing agent binary to $inst (headnode)"
            rsync -av \
                ${AGENT_BIN} \
                $HEADNODE:$prefix/bin/
            restart_or_clear $inst svc:/manta/application/rebalancer-agent
        done
    fi

    # Also sync to storage zones on remote CNs.
    # Unlike the rebalancer manager (one zone), storage zones are typically
    # spread across all CNs.  We must check remote CNs even when some
    # storage zones exist on the headnode.
    echo "==> Checking for storage zones on remote CNs..."
    local remote_zones
    remote_zones=$(find_remote_zones "$alias") || true
    if [[ -n "$remote_zones" ]]; then
        local zone_count=$(echo "$remote_zones" | wc -l | tr -d ' ')
        echo "  Found remote storage zones: $zone_count"
        # Use fd 3 so ssh/rsync inside the loop don't consume the input
        while IFS= read -r line <&3; do
            local inst cn_ip
            inst=$(echo "$line" | awk '{print $1}')
            cn_ip=$(echo "$line" | awk '{print $2}')
            [[ -n "$inst" ]] || continue
            echo "==> Syncing agent binary to $inst (CN $cn_ip)"

            (
                set +o errexit
                sync_files_to_remote_zone "$inst" "$cn_ip" \
                    /opt/smartdc/rebalancer-agent/bin \
                    ${AGENT_BIN}
                restart_or_clear_remote "$inst" "$cn_ip" svc:/manta/application/rebalancer-agent
            ) || echo "  WARNING: failed for $inst on $cn_ip, continuing..."
        done 3<<< "$remote_zones"
    fi
}

# ---- mainline

[[ -n "$1" ]] || fatal "usage: $0 HEADNODE-GZ-IP [manager|agent]"
HEADNODE=root@$1
MODE=${2:-both}

case $MODE in
    manager) sync_manager ;;
    agent)   sync_agent ;;
    both)    sync_manager; sync_agent ;;
    *)       fatal "unknown mode '$MODE' — use 'manager', 'agent', or omit for both" ;;
esac
