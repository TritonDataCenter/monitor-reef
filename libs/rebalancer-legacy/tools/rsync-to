#
# Rsync rebalancer binaries and config to zones for quick dev iteration.
#
# Supports multi-CN deployments where the rebalancer and storage zones
# may be on remote compute nodes, not just the headnode.
#
# Usage:
#   ./tools/rsync-to HEADNODE-GZ-IP           # sync both manager + agent
#   ./tools/rsync-to HEADNODE-GZ-IP manager   # sync manager only
#   ./tools/rsync-to HEADNODE-GZ-IP agent     # sync agent only
#
# Set RELEASE=1 to use target/release/ instead of target/debug/.
#

if [[ -n "$TRACE" ]]; then
    export PS4='[\D{%FT%TZ}] ${BASH_SOURCE}:${LINENO}: ${FUNCNAME[0]:+${FUNCNAME[0]}(): }'
    set -o xtrace
fi
set -o errexit
set -o pipefail

TOP=$(cd $(dirname $0)/../; pwd)
SSH_OPTS="-q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
CN_SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
PROFILE=${RELEASE:+release}
PROFILE=${PROFILE:-debug}
# Workspace root is two levels above libs/rebalancer-legacy/
WORKSPACE_ROOT=$(cd ${TOP}/../..; pwd)
TARGET_DIR=${WORKSPACE_ROOT}/target/${PROFILE}

function fatal {
    echo "$0: fatal error: $*"
    exit 1
}

# Discover zone UUID and the CN admin IP where it runs.
#
# In a multi-CN deployment, vmadm on the headnode only sees local zones.
# We use VMAPI (which has a DC-wide view) to find zones by alias, then
# resolve the server_uuid to a CN admin IP via CNAPI.
#
# Sets: ZONE_UUID, ZONE_CN_IP ("local" if zone is on the headnode)
#
# Usage: find_zone_on_any_cn <alias_pattern>
#        Returns one result per line: "uuid cn_ip"
function find_zones_on_any_cn {
    local alias_pat=$1

    # First try local vmadm (fast path — works if zone is on the headnode)
    local local_insts=$(ssh $SSH_OPTS $HEADNODE \
        "vmadm lookup alias=~$alias_pat state=running" 2>/dev/null || true)

    if [[ -n "$local_insts" ]]; then
        for inst in $local_insts; do
            echo "$inst local"
        done
        return
    fi

    # Zone not on headnode — query VMAPI for DC-wide lookup.
    # VMAPI runs on the headnode and knows about all zones on all CNs.
    echo "  Zone '$alias_pat' not on headnode, querying VMAPI..." >&2

    local vmapi_result
    vmapi_result=$(ssh $SSH_OPTS $HEADNODE \
        "curl -sS 'http://vmapi.coal.joyent.us/vms?alias=$alias_pat&state=running'" \
        2>/dev/null) || fatal "VMAPI query failed"

    local count
    count=$(echo "$vmapi_result" | json length)
    [[ "$count" -gt 0 ]] 2>/dev/null || fatal "no running '$alias_pat' instances found on any CN"

    # For each zone, resolve its server_uuid to a CN admin IP
    for idx in $(seq 0 $(( count - 1 ))); do
        local uuid=$(echo "$vmapi_result" | json $idx.uuid)
        local server_uuid=$(echo "$vmapi_result" | json $idx.server_uuid)
        local headnode_uuid=$(ssh $SSH_OPTS $HEADNODE "sysinfo | json UUID" 2>/dev/null)

        if [[ "$server_uuid" == "$headnode_uuid" ]]; then
            echo "$uuid local"
        else
            # Resolve CN admin IP via CNAPI
            local cn_ip
            cn_ip=$(ssh $SSH_OPTS $HEADNODE \
                "curl -sS 'http://cnapi.coal.joyent.us/servers/$server_uuid' \
                 | json sysinfo.\"Admin IP\"" 2>/dev/null)
            [[ -n "$cn_ip" ]] || fatal "could not resolve admin IP for server $server_uuid"
            echo "$uuid $cn_ip"
        fi
    done
}

# Restart or clear a service inside a zone.
# Handles both local zones (on headnode) and remote zones (on CNs).
#
# Usage: restart_or_clear <zone_uuid> <cn_ip> <fmri>
function restart_or_clear {
    local inst=$1 cn_ip=$2 fmri=$3

    local state
    if [[ "$cn_ip" == "local" ]]; then
        state=$(ssh $SSH_OPTS $HEADNODE \
            "svcs -z $inst -H -o state $fmri" 2>/dev/null || echo "unknown")
    else
        state=$(ssh $SSH_OPTS $HEADNODE \
            "ssh $CN_SSH_OPTS -i /root/.ssh/sdc.id_rsa $cn_ip \
             'svcs -z $inst -H -o state $fmri'" 2>/dev/null || echo "unknown")
    fi

    if echo "$state" | grep "maintenance" >/dev/null; then
        echo "    clearing $fmri (was in maintenance)"
        if [[ "$cn_ip" == "local" ]]; then
            ssh $SSH_OPTS $HEADNODE "svcadm -z $inst clear $fmri"
        else
            ssh $SSH_OPTS $HEADNODE \
                "ssh $CN_SSH_OPTS -i /root/.ssh/sdc.id_rsa $cn_ip \
                 'svcadm -z $inst clear $fmri'"
        fi
    elif echo "$state" | grep "online" >/dev/null; then
        echo "    restarting $fmri"
        if [[ "$cn_ip" == "local" ]]; then
            ssh $SSH_OPTS $HEADNODE "svcadm -z $inst restart $fmri"
        else
            ssh $SSH_OPTS $HEADNODE \
                "ssh $CN_SSH_OPTS -i /root/.ssh/sdc.id_rsa $cn_ip \
                 'svcadm -z $inst restart $fmri'"
        fi
    fi
}

# Rsync files into a zone, handling both local and remote CNs.
#
# For local zones:  rsync directly to headnode:/zones/<uuid>/root/...
# For remote zones: rsync to headnode:/tmp, then scp to CN, then
#                   copy into the zone filesystem.
#
# Usage: sync_files_to_zone <zone_uuid> <cn_ip> <dest_dir> <file1> [file2...]
function sync_files_to_zone {
    local inst=$1 cn_ip=$2 dest_dir=$3
    shift 3
    local files=("$@")

    if [[ "$cn_ip" == "local" ]]; then
        # Zone is on the headnode — rsync directly into the zone fs
        rsync -av "${files[@]}" $HEADNODE:/zones/$inst/root${dest_dir}/
    else
        # Zone is on a remote CN — stage on headnode, push to CN
        local staging=/tmp/rsync-to-$$
        ssh $SSH_OPTS $HEADNODE "mkdir -p $staging"

        rsync -av "${files[@]}" $HEADNODE:$staging/

        # Copy staged files from headnode to CN, then into zone
        for f in "${files[@]}"; do
            local basename=$(basename "$f")
            ssh $SSH_OPTS $HEADNODE \
                "scp $CN_SSH_OPTS -i /root/.ssh/sdc.id_rsa \
                 $staging/$basename $cn_ip:/tmp/$basename && \
                 ssh $CN_SSH_OPTS -i /root/.ssh/sdc.id_rsa $cn_ip \
                 'cp /tmp/$basename /zones/$inst/root${dest_dir}/$basename && \
                  rm /tmp/$basename'"
        done

        # Clean up staging dir
        ssh $SSH_OPTS $HEADNODE "rm -rf $staging"
    fi
}

function sync_manager {
    echo "==> Looking for rebalancer manager zones..."
    local zone_info
    zone_info=$(find_zones_on_any_cn rebalancer)

    echo "$zone_info" | while read inst cn_ip; do
        [[ -n "$inst" ]] || continue
        local loc_label="$cn_ip"
        [[ "$cn_ip" == "local" ]] && loc_label="headnode"
        echo "==> Syncing manager binaries to $inst ($loc_label)"

        [[ -f "${TARGET_DIR}/rebalancer-manager" ]] || \
            fatal "rebalancer-manager not found at ${TARGET_DIR}/rebalancer-manager"
        [[ -f "${TARGET_DIR}/rebalancer-adm" ]] || \
            fatal "rebalancer-adm not found at ${TARGET_DIR}/rebalancer-adm"

        sync_files_to_zone "$inst" "$cn_ip" \
            /opt/smartdc/rebalancer/bin \
            ${TARGET_DIR}/rebalancer-manager \
            ${TARGET_DIR}/rebalancer-adm

        restart_or_clear "$inst" "$cn_ip" svc:/manta/application/rebalancer
    done
}

function sync_agent {
    local alias=${STORAGE_ALIAS:-storage}
    echo "==> Looking for storage zones (alias ~$alias)..."
    local zone_info
    zone_info=$(find_zones_on_any_cn "$alias")

    # Use only the isolated agent build (no libpq).
    # Do NOT fall back to target/ — that binary has postgres linked.
    local AGENT_BIN=${TOP}/target-agent/${PROFILE}/rebalancer-agent
    [[ -f "$AGENT_BIN" ]] || fatal "rebalancer-agent not found at ${AGENT_BIN}
    Run 'make build-legacy' or 'make -C libs/rebalancer-legacy agent' first."

    echo "$zone_info" | while read inst cn_ip; do
        [[ -n "$inst" ]] || continue
        local loc_label="$cn_ip"
        [[ "$cn_ip" == "local" ]] && loc_label="headnode"
        echo "==> Syncing agent binary to $inst ($loc_label)"

        sync_files_to_zone "$inst" "$cn_ip" \
            /opt/smartdc/rebalancer-agent/bin \
            ${AGENT_BIN}

        restart_or_clear "$inst" "$cn_ip" svc:/manta/application/rebalancer-agent
    done
}

# ---- mainline

[[ -n "$1" ]] || fatal "usage: $0 HEADNODE-GZ-IP [manager|agent]"
HEADNODE=root@$1
MODE=${2:-both}

case $MODE in
    manager) sync_manager ;;
    agent)   sync_agent ;;
    both)    sync_manager; sync_agent ;;
    *)       fatal "unknown mode '$MODE' — use 'manager', 'agent', or omit for both" ;;
esac
