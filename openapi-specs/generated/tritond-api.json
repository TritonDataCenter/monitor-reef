            "type": "string"
          },
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "issuer_url": {
            "type": "string"
          }
        },
        "required": [
          "client_id",
          "client_secret",
          "issuer_url"
        ]
      },
      "NewProject": {
        "description": "Request body for creating a project. The owning silo comes from the URL path, not the body.",
        "type": "object",
        "properties": {
          "description": {
            "nullable": true,
            "default": null,
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "NewSilo": {
        "description": "Request body for creating a silo.\n\nDistinct from [`Silo`] because the server assigns `id` and `created_at`. `description` is optional on the wire and stored as an empty string when omitted.",
        "type": "object",
        "properties": {
          "description": {
            "nullable": true,
            "default": null,
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "NewVpc": {
        "description": "Request body for creating a VPC. The owning silo + project come from the URL path, not the body. The server assigns `id`, `vni`, and `created_at`. At least one of `ipv4_block` / `ipv6_block` must be `Some`; the API rejects requests with both `None`.",
        "type": "object",
        "properties": {
