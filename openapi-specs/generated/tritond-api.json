          "username"
        ]
      },
      "NewApiKey": {
        "description": "Request body for `POST /v2/auth/api-keys`.",
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          }
        },
        "required": [
          "description"
        ]
      },
      "NewIdpConfig": {
        "description": "Request body for `POST /v2/silos/{silo_id}/idp`. tritond **eagerly** fetches the IdP's discovery document on this call; a 4xx/5xx return means the IdP isn't reachable or doesn't speak OIDC, and the config is not persisted.",
        "type": "object",
        "properties": {
          "audience": {
            "nullable": true,
