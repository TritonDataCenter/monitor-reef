      "AuditEvent": {
        "description": "Materialised audit event. The `hash` is `SHA-256(canonical-JSON of every field except hash itself)` so a verifier reading any prefix of the chain can recompute and compare.",
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "actor": {
            "$ref": "#/components/schemas/Actor"
          },
          "decision": {
            "$ref": "#/components/schemas/Decision"
          },
          "hash": {
            "type": "string"
          },
          "outcome": {
            "$ref": "#/components/schemas/Outcome"
          },
          "payload": {},
          "prev_hash": {
            "type": "string"
          },
          "request_id": {
            "nullable": true,
            "type": "string",
            "format": "uuid"
          },
          "resource": {
            "nullable": true,
            "type": "string"
          },
          "seq": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "ts": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "action",
          "actor",
          "decision",
          "hash",
          "outcome",
          "payload",
          "prev_hash",
          "seq",
          "ts"
        ]
      },
      "AuditEventList": {
        "description": "Response body for `GET /v2/audit/events`.",
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuditEvent"
            }
          },
          "head": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ChainHead"
              }
            ]
          }
        },
        "required": [
          "events"
        ]
      },
      "AuditVerifyResponse": {
        "description": "Response body for `GET /v2/audit/verify`.",
        "type": "object",
        "properties": {
          "head": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ChainHead"
              }
