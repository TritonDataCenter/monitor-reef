            "nullable": true,
            "default": null,
            "type": "string"
          },
          "ipv4_block": {
            "nullable": true,
            "default": null,
            "type": "string"
          },
          "ipv6_block": {
            "nullable": true,
            "default": null,
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "Outcome": {
        "description": "Outcome of the action after the handler finished.",
        "oneOf": [
          {
            "description": "Handler completed successfully. `resource` carries the affected entity uid when known (e.g. `Silo::\"<uuid>\"`).",
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "success"
                ]
              },
              "resource": {
                "nullable": true,
                "type": "string"
              }
            },
            "required": [
              "kind"
            ]
          },
          {
            "description": "Cedar denied; handler did not run.",
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "forbidden"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          {
            "description": "Authentication failed (bad password, expired token, missing key).",
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "unauthenticated"
                ]
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "reason"
            ]
          },
          {
            "description": "Caller-side error (4xx other than 401/403).",
            "type": "object",
            "properties": {
              "code": {
                "type": "integer",
                "format": "uint16",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "client_error"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "kind",
              "message"
            ]
          },
          {
            "description": "Server-side error (5xx).",
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "server_error"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "message"
            ]
          }
        ]
      },
