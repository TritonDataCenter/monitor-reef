      "VerifyOutcome": {
        "description": "Result of [`crate::Chain::verify`].",
        "oneOf": [
          {
            "description": "The walked range is internally consistent and chains back to `from - 1` correctly. `verified_to` is the highest seq reached.",
            "type": "object",
            "properties": {
              "Ok": {
                "type": "object",
                "properties": {
                  "verified_to": {
                    "type": "integer",
                    "format": "uint64",
                    "minimum": 0
                  }
                },
                "required": [
                  "verified_to"
                ]
              }
            },
            "required": [
              "Ok"
            ],
            "additionalProperties": false
          },
          {
            "description": "Found a hash mismatch. `seq` is the first event whose stored hash does not match its recomputed value, or whose `prev_hash` does not match the prior event's `hash`. The chain bytes themselves remain queryable; the operator decides what to do.",
            "type": "object",
            "properties": {
              "Mismatch": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "seq": {
                    "type": "integer",
                    "format": "uint64",
                    "minimum": 0
                  }
                },
                "required": [
                  "message",
                  "seq"
                ]
              }
            },
            "required": [
              "Mismatch"
            ],
            "additionalProperties": false
          }
        ]
      },
      "Vpc": {
        "description": "Tenant VPC. Project-scoped (Phase 1 URL shape). Mirrors the per-VPC fields OPTE consumes in `oxide_vpc::api::VpcCfg`: a 24-bit Geneve VNI plus an optional primary IPv4 CIDR and optional primary IPv6 CIDR (matching OPTE's `IpCfg` enum: Ipv4-only, Ipv6-only, or dual-stack). Per-NIC concerns (guest MAC, private IPs, external IPs, attached_subnets, DHCP) are *not* on the VPC record — those land on subnet/instance/NIC resources in later slices.",
        "type": "object",
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ipv4_block": {
            "nullable": true,
            "description": "Primary IPv4 CIDR for the VPC overlay. `None` for IPv6-only. Wire format is the canonical CIDR string, e.g. `\"10.0.0.0/24\"`.",
            "type": "string"
          },
          "ipv6_block": {
            "nullable": true,
            "description": "Primary IPv6 CIDR for the VPC overlay. `None` for IPv4-only. Wire format is the canonical CIDR string, e.g. `\"fd00::/48\"`.",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "project_id": {
            "type": "string",
            "format": "uuid"
          },
          "silo_id": {
            "type": "string",
            "format": "uuid"
          },
          "vni": {
            "description": "Geneve Virtual Network Identifier. Server-assigned at create time, drawn from `[VPC_VNI_RESERVED_CEILING, VPC_VNI_MAX)`, unique rack-wide.",
            "type": "integer",
            "format": "uint32",
            "minimum": 0
          }
        },
        "required": [
          "created_at",
          "description",
          "id",
          "name",
          "project_id",
          "silo_id",
          "vni"
        ]
      }
    },
    "responses": {
