{
  "openapi": "3.0.3",
  "info": {
    "title": "Triton Cloud Control Plane",
    "description": "Triton Cloud control-plane API. Phase 0 surface (`/v2/health`); subsequent phases add silos, instances, VPCs, audit, secrets, and the rest of DESIGN.md §14.",
    "version": "0.1.0"
  },
  "paths": {
    "/v2/audit/events": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Page through audit events. Returns at most `limit` events with",
        "description": "`seq > after_seq` plus the current chain head.",
        "operationId": "list_audit_events",
        "parameters": [
          {
            "in": "query",
            "name": "after_seq",
            "description": "Return events with `seq > after_seq`. Default 0 (start of chain).",
            "schema": {
              "nullable": true,
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          {
            "in": "query",
            "name": "limit",
            "description": "Maximum events to return. Default 100, max 1000.",
            "schema": {
              "nullable": true,
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEventList"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/audit/events/{seq}": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Fetch a single audit event by sequence number.",
        "operationId": "get_audit_event",
        "parameters": [
          {
            "in": "path",
            "name": "seq",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEvent"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/audit/verify": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Walk the audit chain in `[from, to]` and recompute hashes.",
        "description": "Returns the first divergence (if any) plus the current head. Cheap on small ranges; auditors typically walk the entire chain once per export.",
        "operationId": "verify_audit_chain",
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "description": "First seq to walk. Default 0.",
            "schema": {
              "nullable": true,
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          {
            "in": "query",
            "name": "to",
            "description": "Last seq to walk. Default = current chain head.",
            "schema": {
              "nullable": true,
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditVerifyResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/api-keys": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "List the calling user's API keys. The plaintext secret is never",
        "description": "returned by this endpoint.",
        "operationId": "list_api_keys",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Array_of_ApiKeyView",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKeyView"
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Create a long-lived API key for the calling user. The plaintext",
        "description": "secret is included in the response **once** and never shown again.",
        "operationId": "create_api_key",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewApiKey"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyCreated"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/api-keys/{api_key_id}": {
      "delete": {
        "tags": [
          "auth"
        ],
        "summary": "Delete one of the calling user's API keys. Returns 404 if the",
        "description": "id does not belong to the calling user.",
        "operationId": "delete_api_key",
        "parameters": [
          {
            "in": "path",
            "name": "api_key_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful deletion"
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Exchange username + password for an access/refresh token pair.",
        "description": "Returns 401 if credentials are invalid.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/refresh": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Exchange a valid refresh token for a fresh access/refresh pair.",
        "description": "Returns 401 if the refresh token is invalid or expired.",
        "operationId": "refresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Liveness check. Returns service status and version string.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos": {
      "post": {
        "tags": [
          "silos"
        ],
        "summary": "Create a silo. Returns 201 with the created silo.",
        "description": "Fails with 409 if a silo with the requested name already exists.",
        "operationId": "create_silo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewSilo"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Silo"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}": {
      "get": {
        "tags": [
          "silos"
        ],
        "summary": "Look up a silo by id. Returns 404 if no such silo exists.",
        "operationId": "get_silo",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Silo"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}/idp": {
      "get": {
        "tags": [
          "silos",
          "auth"
        ],
        "summary": "Read the OIDC IdP config for a silo. The client secret is",
        "description": "never returned. 404 when no IdP is configured.",
        "operationId": "get_silo_idp",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdpConfigView"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "silos",
          "auth"
        ],
        "summary": "Configure the OIDC identity provider for a silo. Returns 502",
        "description": "if the discovery document cannot be fetched, 404 if the silo does not exist, otherwise 201 with the redacted view of what was persisted.",
        "operationId": "put_silo_idp",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewIdpConfig"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdpConfigView"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "delete": {
        "tags": [
          "silos",
          "auth"
        ],
        "summary": "Remove the OIDC IdP config for a silo. Federated users in",
        "description": "that silo will fail to authenticate until a new config is posted.",
        "operationId": "delete_silo_idp",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful deletion"
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}/projects": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "List the projects inside a silo.",
        "operationId": "list_silo_projects",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Array_of_Project",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "projects"
        ],
        "summary": "Create a project in a silo. Returns 409 if the project name",
        "description": "is already in use within that silo.",
        "operationId": "create_silo_project",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewProject"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}/projects/{project_id}": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "Read a single project. Returns 404 when the project does not",
        "description": "exist or belongs to a different silo (cross-silo probes do not learn that other silos exist).",
        "operationId": "get_silo_project",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "delete": {
        "tags": [
          "projects"
        ],
        "summary": "Delete a project. Returns 404 when the project does not exist",
        "description": "or belongs to a different silo.",
        "operationId": "delete_silo_project",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful deletion"
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}/projects/{project_id}/vpcs": {
      "get": {
        "tags": [
          "vpcs"
        ],
        "summary": "List the VPCs inside a project. Returns 404 when the silo or",
        "description": "project does not exist (or the project belongs to a different silo).",
        "operationId": "list_project_vpcs",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Array_of_Vpc",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Vpc"
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "vpcs"
        ],
        "summary": "Create a VPC in a project. Returns 400 if neither `ipv4_block`",
        "description": "nor `ipv6_block` is provided. Returns 409 if a VPC with the same name already exists in the project. The server assigns `id`, `vni` (random in `[4096, 2^24)`, unique rack-wide), and `created_at`.",
        "operationId": "create_project_vpc",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewVpc"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vpc"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}/projects/{project_id}/vpcs/{vpc_id}": {
      "get": {
        "tags": [
          "vpcs"
        ],
        "summary": "Read a single VPC. Returns 404 when the VPC does not exist or",
        "description": "belongs to a different silo or project (cross-tenant probes do not learn that the resource exists).",
        "operationId": "get_project_vpc",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "vpc_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vpc"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "delete": {
        "tags": [
          "vpcs"
        ],
        "summary": "Delete a VPC. Returns 404 when the VPC does not exist or",
        "description": "belongs to a different silo or project.",
        "operationId": "delete_project_vpc",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "in": "path",
            "name": "vpc_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful deletion"
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Actor": {
        "description": "Who initiated the action.",
        "oneOf": [
          {
            "description": "Authenticated operator with an `is_root` flag captured at the time of the event.",
            "type": "object",
            "properties": {
              "is_root": {
                "type": "boolean"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "operator"
                ]
              },
              "user_id": {
                "type": "string",
                "format": "uuid"
              }
            },
            "required": [
              "is_root",
              "kind",
              "user_id"
            ]
          },
          {
            "description": "Authenticated via API key. `key_id` lets auditors trace the credential without revealing it.",
            "type": "object",
            "properties": {
              "key_id": {
                "type": "string",
                "format": "uuid"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "api_key"
                ]
              },
              "user_id": {
                "type": "string",
                "format": "uuid"
              }
            },
