{
  "openapi": "3.0.3",
  "info": {
    "title": "Triton Cloud Control Plane",
    "description": "Triton Cloud control-plane API. Phase 0 surface (`/v2/health`); subsequent phases add silos, instances, VPCs, audit, secrets, and the rest of DESIGN.md §14.",
    "version": "0.1.0"
  },
  "paths": {
    "/v2/auth/api-keys": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "List the calling user's API keys. The plaintext secret is never",
        "description": "returned by this endpoint.",
        "operationId": "list_api_keys",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Array_of_ApiKeyView",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKeyView"
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Create a long-lived API key for the calling user. The plaintext",
        "description": "secret is included in the response **once** and never shown again.",
        "operationId": "create_api_key",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewApiKey"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyCreated"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/api-keys/{api_key_id}": {
      "delete": {
        "tags": [
          "auth"
        ],
        "summary": "Delete one of the calling user's API keys. Returns 404 if the",
        "description": "id does not belong to the calling user.",
        "operationId": "delete_api_key",
        "parameters": [
          {
            "in": "path",
            "name": "api_key_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful deletion"
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Exchange username + password for an access/refresh token pair.",
        "description": "Returns 401 if credentials are invalid.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/auth/refresh": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Exchange a valid refresh token for a fresh access/refresh pair.",
        "description": "Returns 401 if the refresh token is invalid or expired.",
        "operationId": "refresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Liveness check. Returns service status and version string.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos": {
      "post": {
        "tags": [
          "silos"
        ],
        "summary": "Create a silo. Returns 201 with the created silo.",
        "description": "Fails with 409 if a silo with the requested name already exists.",
        "operationId": "create_silo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewSilo"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "successful creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Silo"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/v2/silos/{silo_id}": {
      "get": {
        "tags": [
          "silos"
        ],
        "summary": "Look up a silo by id. Returns 404 if no such silo exists.",
        "operationId": "get_silo",
        "parameters": [
          {
            "in": "path",
            "name": "silo_id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Silo"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiKeyCreated": {
        "description": "Response body for `POST /v2/auth/api-keys`.\n\n`secret` is the wire-form key. It is shown to the operator **once**; the server retains only a bcrypt hash.",
        "type": "object",
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "secret": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "created_at",
          "description",
          "id",
          "secret",
          "user_id"
        ]
      },
      "ApiKeyView": {
        "description": "Wire-safe view of an [`ApiKey`]: identifying metadata, no hash.",
        "type": "object",
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "created_at",
          "description",
          "id",
          "user_id"
        ]
      },
      "Error": {
        "description": "Error information from a response.",
        "type": "object",
        "properties": {
          "error_code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "request_id"
        ]
      },
      "HealthResponse": {
        "description": "Liveness response.",
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ]
      },
      "LoginRequest": {
        "description": "Request body for `POST /v2/auth/login`.",
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        },
        "required": [
          "password",
          "username"
        ]
      },
      "NewApiKey": {
        "description": "Request body for `POST /v2/auth/api-keys`.",
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          }
        },
        "required": [
          "description"
        ]
      },
      "NewSilo": {
        "description": "Request body for creating a silo.\n\nDistinct from [`Silo`] because the server assigns `id` and `created_at`. `description` is optional on the wire and stored as an empty string when omitted.",
        "type": "object",
        "properties": {
          "description": {
            "nullable": true,
            "default": null,
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "RefreshRequest": {
        "description": "Request body for `POST /v2/auth/refresh`.",
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ]
      },
      "Silo": {
        "description": "A tenancy boundary. Every Triton Cloud resource ultimately rolls up to a silo; in production each silo is bound to its own identity provider. Phase 0 carries only the bare-minimum identifying fields.",
        "type": "object",
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "created_at",
          "description",
          "id",
          "name"
        ]
      },
      "TokenResponse": {
        "description": "Response body for both login and refresh.",
        "type": "object",
        "properties": {
          "access_expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "access_token": {
            "type": "string"
          },
          "refresh_expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "refresh_token": {
            "type": "string"
          }
        },
        "required": [
          "access_expires_at",
          "access_token",
          "refresh_expires_at",
          "refresh_token"
        ]
      }
    },
    "responses": {
      "Error": {
        "description": "Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "auth"
    },
    {
      "name": "silos"
    },
    {
      "name": "system"
    }
  ]
}
