        "description": "Response body for both login and refresh.",
        "type": "object",
        "properties": {
          "access_expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "access_token": {
            "type": "string"
          },
          "refresh_expires_at": {
            "type": "string",
            "format": "date-time"
          },
