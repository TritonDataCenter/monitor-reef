{
  "openapi": "3.0.3",
  "info": {
    "title": "Triton API",
    "description": "Triton API - public-facing HTTP API for the Triton datacenter",
    "version": "0.1.0"
  },
  "paths": {
    "/v1/ping": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Ping",
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/Error"
          },
          "5XX": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "description": "Error information from a response.",
        "type": "object",
        "properties": {
          "error_code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        },
        "required": [
          "message",
          "request_id"
        ]
      },
      "PingResponse": {
        "description": "Ping response",
        "type": "object",
        "properties": {
          "healthy": {
            "nullable": true,
            "description": "Health check status",
            "type": "boolean"
          },
          "status": {
            "description": "Ping status (e.g., \"OK\")",
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    "responses": {
      "Error": {
        "description": "Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "system"
    }
  ]
}
