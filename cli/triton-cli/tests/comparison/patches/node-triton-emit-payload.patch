+    // Emit-payload mode: intercept API requests without sending them
+    if (process.env.TRITON_EMIT_PAYLOAD) {
+        var m = method.toUpperCase();
+        var envelope = {
+            method: m,
+            path: opts.path,
+            body: (m === 'GET' || m === 'HEAD') ? null : (opts.data || null)
+        };
+        console.log(JSON.stringify(envelope, null, 2));
+
+        // Load shared fixture file (cached on constructor)
+        if (!CloudApi._fixtures && process.env.TRITON_EMIT_PAYLOAD_FIXTURES) {
+            try {
+                CloudApi._fixtures = JSON.parse(
+                    require('fs').readFileSync(
+                        process.env.TRITON_EMIT_PAYLOAD_FIXTURES, 'utf8'));
+            } catch (_e) { /* ignore load errors */ }
+        }
+        var fix = CloudApi._fixtures || {};
+        var resps = fix.responses || {};
+
+        // Derive operation_id from method + URL path
+        var segs = opts.path.replace(/\?.*$/, '').split('/').filter(Boolean);
+        var rMap = {machines:'machine', images:'image', packages:'package',
+            networks:'network', volumes:'volume', keys:'key',
+            fwrules:'firewall_rule', vlans:'fabric_vlan',
+            nics:'nic', snapshots:'machine_snapshot', disks:'machine_disk'};
+        var opId = null;
+        for (var i = segs.length - 1; i >= 0; i--) {
+            var r = rMap[segs[i]];
+            if (!r) continue;
+            if (segs[i] === 'networks' && opts.path.indexOf('/fabrics/') !== -1)
+                r = 'fabric_network';
+            var hasId = i < segs.length - 1;
+            if (m === 'GET' || m === 'HEAD') opId = hasId ? 'get_' + r : 'list_' + r;
+            else if (m === 'POST') opId = hasId ? 'update_' + r : 'create_' + r;
+            else if (m === 'PUT') opId = 'update_' + r;
+            else if (m === 'DELETE') opId = 'delete_' + r;
+            break;
+        }
+
+        // Interpolate placeholders in fixture template
+        var lastSeg = segs[segs.length - 1] || 'unknown';
+        var lastSegUuid = /^[0-9a-f]{8}-/.test(lastSeg) ? lastSeg
+            : '00000000-0000-0000-0000-000000000000';
+        var vlanMatch = opts.path.match(/\/vlans\/(\d+)/);
+        var vlanId = vlanMatch ? parseInt(vlanMatch[1], 10) : 0;
+        function interp(o) {
+            var s = JSON.stringify(o);
+            s = s.replace(/\$LAST_SEG_UUID/g, lastSegUuid);
+            s = s.replace(/\$LAST_SEG/g, lastSeg);
+            s = s.replace(/"\$VLAN_ID"/g, String(vlanId));
+            return JSON.parse(s);
+        }
+
+        // Look up fixture response, with fallback defaults
+        var resp;
+        if (opId && resps[opId]) {
+            resp = interp(resps[opId]);
+        } else if (m === 'GET' || m === 'HEAD') {
+            resp = opId && opId.indexOf('list_') === 0
+                ? (fix.list_default || [])
+                : interp(fix.get_default || {id: '$LAST_SEG', name: '$LAST_SEG'});
+        } else {
+            resp = fix.mutation_default || {};
+        }
+
+        var fakeRes = { statusCode: 200, headers: {} };
+        if (Array.isArray(resp)) {
+            fakeRes.headers['x-resource-count'] = String(resp.length);
+        }
+        cb(null, null, fakeRes, resp);
+        return;
+    }
+
