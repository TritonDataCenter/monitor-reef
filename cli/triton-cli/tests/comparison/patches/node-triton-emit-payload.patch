+                cb(null, null, { statusCode: 200 }, {id: lastSeg, name: lastSeg});
+            }
+        } else if (/\/nics$/.test(opts.path) && m === 'POST') {
+            // NIC create: node accesses nic.mac
+            cb(null, null, { statusCode: 200 }, {mac: '00:00:00:00:00:00', primary: false, ip: '0.0.0.0', state: 'running', network: 'fake'});
+        } else if (/\/vlans\/\d+$/.test(opts.path) && (m === 'PUT' || m === 'POST')) {
+            // VLAN update: node expects vlan-shaped response
+            var vlanMatch = opts.path.match(/\/vlans\/(\d+)$/);
+            var vlanId = vlanMatch ? parseInt(vlanMatch[1], 10) : 0;
+            cb(null, null, { statusCode: 200 }, {vlan_id: vlanId, name: 'fake', description: ''});
+        } else {
+            cb(null, null, { statusCode: 200 }, {});
+        }
+        return;
+    }
