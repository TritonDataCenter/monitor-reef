<!--
    Copyright 2026 Edgecast Cloud LLC.

    Re-establishes /etc/bash/bash_completion.d/{tritonadm,triton} symlinks
    on every boot. /etc lives on the SmartOS ramdisk, so the symlinks
    don't survive a reboot; this transient service runs the method script
    after the local filesystems are mounted to recreate them. Mirrors
    smartdc/sdcadm-setup.
-->

<service_bundle type='manifest' name='tritonadm-setup'>
  <service name='triton/tritonadm-setup' type='service' version='0'>
    <create_default_instance enabled='true'/>
    <single_instance/>
    <dependency name='filesystem' grouping='require_all' restart_on='none' type='service'>
      <service_fmri value='svc:/system/filesystem/local'/>
    </dependency>
    <exec_method name='start' type='method' exec='/opt/triton/tritonadm/smf/method/tritonadm-setup' timeout_seconds='60'/>
    <exec_method name='stop' type='method' exec=':true' timeout_seconds='0'/>
    <exec_method name='refresh' type='method' exec='/opt/triton/tritonadm/smf/method/tritonadm-setup' timeout_seconds='60'/>
    <property_group name='startd' type='framework'>
      <propval name='duration' type='astring' value='transient'/>
    </property_group>
    <stability value='Unstable'/>
    <template>
      <common_name>
        <loctext xml:lang='C'>tritonadm setup</loctext>
      </common_name>
    </template>
  </service>
</service_bundle>
