#
# SMF start method for site/triton-mantad. Idempotent: distinguishes
# fresh provision from attach-existing by the presence of /data/version.
#
# Reads operator metadata via mdata-get:
#   triton:mantad_public_listen    (optional)  default "0.0.0.0:7443"
#   triton:mantad_internal_listen  (optional)  default "127.0.0.1:7101"
#   triton:mantad_region           (optional)  default "us-east-1"
#   triton:mantad_endpoint_url     (optional)  default "http://<primary-ip>:7443"
#   triton:mantad_admin_token              (optional override) auto-minted if absent
#   triton:mantad_root_access_key_id       (optional override) auto-minted if absent
#   triton:mantad_root_secret_access_key   (optional override) auto-minted if absent
#
# Persistent layout (all on the delegated /data dataset so reprovision
# is safe):
#   /data/version                    sentinel; presence => attach-existing
#   /data/etc/mantad/mantad.toml     rendered every boot from mdata
#   /data/etc/mantad/secrets.env     minted once; the sourced env file
#                                    SMF method uses for MANTAD_* env
#   /data/state/mantad/meta/         raft + fjall metadata
#   /data/state/mantad/data/         local object-store blob dir
#   /data/state/mantad/identity/     standalone identity fjall keyspace
#
# Backgrounds mantad and exits 0 so SMF's exec_method timeout does not
# kill the contract.

set -eu

DATA_VERSION_FILE=/data/version
EXPECTED_DATA_VERSION=1
ETC=/data/etc/mantad
STATE=/data/state/mantad
MANTAD_BIN=/opt/triton/mantad/bin/mantad
LOG_DIR=/data/state/mantad/log

mkdir -p "$ETC" "$STATE/meta" "$STATE/data" "$STATE/identity" "$LOG_DIR"

# --- mdata-driven config (re-rendered every boot) ---
PUBLIC_LISTEN="$(mdata-get triton:mantad_public_listen 2>/dev/null || echo "0.0.0.0:7443")"
INTERNAL_LISTEN="$(mdata-get triton:mantad_internal_listen 2>/dev/null || echo "127.0.0.1:7101")"
REGION="$(mdata-get triton:mantad_region 2>/dev/null || echo "us-east-1")"

# Default endpoint URL: figure out the zone's primary admin IP from
# the routing table; operator can override via mdata for clarity.
PRIMARY_IP="$(ipadm show-addr -p -o ADDR | grep -v ^127 | head -1 | cut -d/ -f1)"
ENDPOINT_URL="$(mdata-get triton:mantad_endpoint_url 2>/dev/null || echo "http://${PRIMARY_IP}:7443")"

# --- bootstrap secrets on first boot only ---
SECRETS_ENV="$ETC/secrets.env"
if [ ! -f "$SECRETS_ENV" ]; then
    echo "triton-mantad: minting first-boot secrets into $SECRETS_ENV" >&2
    ADMIN_TOKEN="$(mdata-get triton:mantad_admin_token 2>/dev/null \
        || head -c 32 /dev/urandom | openssl base64 -A | tr -d '=+/' | head -c 40)"
    ROOT_AK="$(mdata-get triton:mantad_root_access_key_id 2>/dev/null \
        || (printf 'AKIA'; head -c 12 /dev/urandom | openssl base64 -A | tr -d '=+/' \
            | tr 'a-z' 'A-Z' | head -c 16))"
    ROOT_SK="$(mdata-get triton:mantad_root_secret_access_key 2>/dev/null \
        || head -c 32 /dev/urandom | openssl base64 -A | tr -d '=+/' | head -c 40)"
    umask 077
    cat > "$SECRETS_ENV" <<EOF
MANTAD_ADMIN_TOKEN=$ADMIN_TOKEN
MANTAD_ROOT_ACCESS_KEY_ID=$ROOT_AK
MANTAD_ROOT_SECRET_ACCESS_KEY=$ROOT_SK
EOF
    chmod 0600 "$SECRETS_ENV"
fi

# --- render mantad.toml every boot ---
cat > "$ETC/mantad.toml" <<EOF
# Generated by /var/svc/method/triton-mantad on every boot.
# Persistent secrets live in $SECRETS_ENV (mode 0600); mdata-driven
# overrides feed through here. Edit the template, not this file.
listen           = "$PUBLIC_LISTEN"
internal_listen  = "$INTERNAL_LISTEN"
meta_dir         = "$STATE/meta"
data_dir         = "$STATE/data"
owner            = "root"
endpoint         = "$ENDPOINT_URL"
peers            = ""
replication      = 1

[identity]
mode = "standalone"
[identity.standalone]
data_dir = "$STATE/identity"
EOF
chmod 0644 "$ETC/mantad.toml"

# --- launch mantad with the persistent env, background + exit 0 ---
# shellcheck disable=SC1090
. "$SECRETS_ENV"
export MANTAD_ADMIN_TOKEN MANTAD_ROOT_ACCESS_KEY_ID MANTAD_ROOT_SECRET_ACCESS_KEY
export MANTAD_REGION="$REGION"
export RUST_LOG="${RUST_LOG:-info}"

"$MANTAD_BIN" --config "$ETC/mantad.toml" \
    >>"$LOG_DIR/mantad.out" 2>>"$LOG_DIR/mantad.err" &
MANTAD_PID=$!
echo "triton-mantad: mantad launched pid=$MANTAD_PID region=$REGION listen=$PUBLIC_LISTEN" >&2

# Mark the data layout version on first successful boot so reprovision
# attach-existing path can detect the schema version.
if [ ! -f "$DATA_VERSION_FILE" ]; then
    printf '%s\n' "$EXPECTED_DATA_VERSION" > "$DATA_VERSION_FILE"
    chmod 0644 "$DATA_VERSION_FILE"
fi

exit 0
