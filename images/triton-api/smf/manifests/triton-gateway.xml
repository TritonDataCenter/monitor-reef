<service_bundle type="manifest" name="triton-gateway">
    <service name="triton/application/triton-gateway" type="service" version="1">
        <create_default_instance enabled="true"/>
        <single_instance/>

        <dependency name="postboot" grouping="require_all" restart_on="none"
            type="service">
            <service_fmri value="svc:/site/postboot:default"/>
        </dependency>

        <dependency name="network" grouping="require_all" restart_on="error"
            type="service">
            <service_fmri value="svc:/milestone/network:default"/>
        </dependency>

        <!-- Gateway depends on triton-api being available -->
        <dependency name="triton-api" grouping="require_all" restart_on="restart"
            type="service">
            <service_fmri value="svc:/triton/application/triton-api:default"/>
        </dependency>

        <exec_method type="method" name="start"
            exec="/opt/triton/triton-api/triton-gateway &amp;"
            timeout_seconds="60">
            <method_context>
                <method_environment>
                    <envvar name="TRITON__CONFIG_FILE"
                        value="/opt/triton/triton-api/etc/gateway-config.json"/>
                </method_environment>
            </method_context>
        </exec_method>

        <exec_method type="method" name="stop" exec=":kill"
            timeout_seconds="60">
            <method_context/>
        </exec_method>

        <exec_method type="method" name="refresh" exec=":kill -HUP"
            timeout_seconds="60">
            <method_context/>
        </exec_method>

        <property_group name="startd" type="framework">
            <propval name="duration" type="astring" value="contract"/>
        </property_group>

        <stability value="Evolving"/>
    </service>
</service_bundle>
