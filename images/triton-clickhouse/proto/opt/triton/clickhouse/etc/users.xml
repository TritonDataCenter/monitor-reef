<!--
    Default users config. ClickHouse rewrites + augments user config
    at runtime via the access_management interface; this file is
    the seed for the `default` user. Operators can ALTER USER it
    after first boot.
-->
<clickhouse>
    <profiles>
        <default><max_memory_usage>6000000000</max_memory_usage></default>
    </profiles>
    <users>
        <default>
            <password></password>
            <networks><ip>::/0</ip></networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>
    <quotas><default><interval><duration>3600</duration><queries>0</queries></interval></default></quotas>
</clickhouse>
